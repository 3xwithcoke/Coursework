"""
Question 2: Hydropower Plant Cascade – Maximum Path Sum in a Binary Tree

Problem:
Given the root of a binary tree where each node represents an energy gain or loss value,
determine the maximum path sum. A path may start and end at any node in the tree, but it
must follow parent-child connections and cannot revisit nodes.

Logic:
We perform a Depth-First Search (DFS) traversal of the binary tree.

For every node we compute:
1. Gain from the node:
   The maximum sum path starting from this node and extending to one of its children.

2. Best path through the node:
   The node value plus the maximum gain from the left subtree and the maximum gain
   from the right subtree.

If a subtree produces a negative gain, we ignore it using max(0, gain) because including
it would decrease the total path sum.

A global variable 'best_sum' keeps track of the maximum path sum encountered during
the traversal.
"""

from typing import Optional


class TreeNode:
    """
    Represents a node in the binary tree.
    """

    def __init__(self, val: int = 0, left: Optional['TreeNode'] = None, right: Optional['TreeNode'] = None):
        self.val = val
        self.left = left
        self.right = right


def max_path_sum(root: TreeNode) -> int:
    """
    Computes the maximum path sum in the binary tree.

    Args:
        root: The root node of the binary tree.

    Returns:
        The maximum path sum found in the tree.
    """

    best_sum = float("-inf")

    def dfs(node: Optional[TreeNode]) -> int:
        """
        Performs DFS traversal and computes maximum gain from the node.

        Args:
            node: Current node being processed.

        Returns:
            Maximum gain that can be extended to the parent.
        """
        nonlocal best_sum

        if node is None:
            return 0

        # Compute maximum gain from left and right subtrees
        left_gain = max(0, dfs(node.left))
        right_gain = max(0, dfs(node.right))

        # Maximum path sum passing through this node
        current_path_sum = node.val + left_gain + right_gain

        # Update global maximum
        best_sum = max(best_sum, current_path_sum)

        # Return gain to parent node
        return node.val + max(left_gain, right_gain)

    dfs(root)
    return best_sum


def main():
    """
    Main function to test the algorithm with example trees.
    """

    print("--- Question 2: Hydropower Plant Cascade ---")

    # Example 1
    # Tree: [1,2,3]
    #       1
    #      / \
    #     2   3
    root1 = TreeNode(1, TreeNode(2), TreeNode(3))

    result1 = max_path_sum(root1)

    print("Example 1 Tree: [1,2,3]")
    print(f"Output: {result1}")
    print("Expected: 6\n")

    # Example 2
    # Tree: [-10,9,20,null,null,15,7]
    #
    #        -10
    #        /  \
    #       9   20
    #          /  \
    #         15   7
    root2 = TreeNode(
        -10,
        TreeNode(9),
        TreeNode(20, TreeNode(15), TreeNode(7))
    )

    result2 = max_path_sum(root2)

    print("Example 2 Tree: [-10,9,20,null,null,15,7]")
    print(f"Output: {result2}")
    print("Expected: 42\n")

    # Example 3 (Single negative node)
    root3 = TreeNode(-3)

    result3 = max_path_sum(root3)

    print("Example 3 Tree: [-3]")
    print(f"Output: {result3}")
    print("Expected: -3\n")


if __name__ == "__main__":
    main()