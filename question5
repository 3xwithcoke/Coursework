"""
Question 5: Network Delay Time – Smart City Communication System

Problem:
In a smart city communication network, signals are sent from one central
node to all other nodes. The network is represented as a directed graph
where each edge has a travel time.

Given:
times[i] = (u, v, w) meaning a signal takes w time to travel
from node u to node v.

We must determine how long it takes for the signal to reach all nodes
in the network. If it is impossible for all nodes to receive the signal,
we return -1.

Logic:
We solve this problem using Dijkstra’s Algorithm.

Steps:
1. Build an adjacency list to represent the graph.
2. Use a priority queue (min heap) to always process the node
   with the smallest current time.
3. Update the shortest known time for each node.
4. Continue until all reachable nodes are processed.

The maximum time among all shortest paths represents the time required
for the signal to reach the entire network.
"""

from typing import List, Tuple
import heapq


def network_delay_time(times: List[Tuple[int, int, int]], n: int, k: int) -> int:
    """
    Calculates the time required for a signal to reach all nodes.

    Args:
        times: List of edges (u, v, w)
        n: Total number of nodes
        k: Starting node (signal source)

    Returns:
        Total time for signal to reach all nodes, or -1 if impossible.
    """

    # Build adjacency list
    graph = {i: [] for i in range(1, n + 1)}

    for u, v, w in times:
        graph[u].append((v, w))

    # Priority queue: (time, node)
    pq = [(0, k)]

    visited = {}

    while pq:
        time, node = heapq.heappop(pq)

        if node in visited:
            continue

        visited[node] = time

        for neighbor, weight in graph[node]:
            if neighbor not in visited:
                heapq.heappush(pq, (time + weight, neighbor))

    if len(visited) != n:
        return -1

    return max(visited.values())


def main():
    """
    Main function to test the algorithm.
    """

    print("--- Question 5: Network Delay Time ---")

    # Example 1
    times1 = [(2, 1, 1), (2, 3, 1), (3, 4, 1)]
    n1 = 4
    k1 = 2

    result1 = network_delay_time(times1, n1, k1)

    print(f"Input: times = {times1}, n = {n1}, k = {k1}")
    print(f"Output: {result1}")
    print("Expected: 2\n")

    # Example 2
    times2 = [(1, 2, 1)]
    n2 = 2
    k2 = 1

    result2 = network_delay_time(times2, n2, k2)

    print(f"Input: times = {times2}, n = {n2}, k = {k2}")
    print(f"Output: {result2}")
    print("Expected: 1\n")

    # Example 3 (Unreachable node)
    times3 = [(1, 2, 1)]
    n3 = 2
    k3 = 2

    result3 = network_delay_time(times3, n3, k3)

    print(f"Input: times = {times3}, n = {n3}, k = {k3}")
    print(f"Output: {result3}")
    print("Expected: -1\n")


if __name__ == "__main__":
    main()